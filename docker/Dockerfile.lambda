FROM public.ecr.aws/lambda/python:3.12 AS base
COPY --from=ghcr.io/astral-sh/uv:0.9.7 /uv /uvx /bin/

RUN dnf update -y && \
    dnf install -y gcc python3-devel git && \
    dnf clean all

# uv builds the locked environment at /opt/venv; PYTHONPATH puts its
# site-packages on the Lambda runtime's import path alongside the task root.
ENV UV_COMPILE_BYTECODE=1 UV_PROJECT_ENVIRONMENT=/opt/venv
ADD pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project --no-dev --extra lambda --python /var/lang/bin/python3.12
ENV PYTHONPATH="/opt/venv/lib/python3.12/site-packages:${LAMBDA_TASK_ROOT}"
COPY pr_agent/ ${LAMBDA_TASK_ROOT}/pr_agent/

FROM base AS github_lambda
CMD ["pr_agent.servers.github_lambda_webhook.lambda_handler"]

FROM base AS gitlab_lambda
CMD ["pr_agent.servers.gitlab_lambda_webhook.lambda_handler"]

FROM github_lambda
